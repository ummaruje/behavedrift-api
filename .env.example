# ============================================================
# BehaveDrift API — Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values.
# NEVER commit your .env file — it is in .gitignore.
# All values here are safe examples with no real secrets.
# ============================================================

# ------------------------------------------------------------
# Application
# ------------------------------------------------------------
APP_NAME=BehaveDrift API
APP_ENV=development              # development | staging | production
APP_PORT=8000
APP_HOST=0.0.0.0
DEBUG=true                       # Set to false in production
LOG_LEVEL=INFO                   # DEBUG | INFO | WARNING | ERROR
LOG_FORMAT=pretty                # pretty (dev) | json (production)
ALLOWED_HOSTS=["localhost","127.0.0.1"]

# ------------------------------------------------------------
# Database (PostgreSQL)
# ------------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://behavedrift:behavedrift_dev@localhost:5432/behavedrift_dev
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20
DATABASE_ECHO=false              # Set to true to log SQL queries (dev only)

# Test database (used by make test)
TEST_DATABASE_URL=postgresql+asyncpg://behavedrift:behavedrift_dev@localhost:5432/behavedrift_test

# ------------------------------------------------------------
# Redis (for rate limiting and webhook queue)
# ------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0

# ------------------------------------------------------------
# Authentication — JWT (OAuth 2.0)
# ------------------------------------------------------------
# Generate with: openssl genrsa -out private.pem 2048
JWT_PRIVATE_KEY_PATH=./keys/private.pem
JWT_PUBLIC_KEY_PATH=./keys/public.pem
JWT_ALGORITHM=RS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# For development only — symmetric secret (NOT for production)
JWT_SECRET_KEY=dev-only-secret-change-this-in-production-immediately

# ------------------------------------------------------------
# API Key Auth (simpler alternative to OAuth2)
# ------------------------------------------------------------
API_KEY_HEADER_NAME=X-API-Key
API_KEY_MIN_LENGTH=32

# ------------------------------------------------------------
# Tenant Configuration
# ------------------------------------------------------------
# Maximum residents per tenant (0 = unlimited)
TENANT_RESIDENT_LIMIT=0

# ------------------------------------------------------------
# Drift Detection Engine
# ------------------------------------------------------------
# Rolling baseline window (days)
BASELINE_WINDOW_DAYS=28

# Recency weighting — how much more recent observations count
BASELINE_RECENCY_WEIGHT=1.5

# Drift alert thresholds (0.0–1.0, higher = more conservative)
DRIFT_ALERT_THRESHOLD_T1=0.40   # Watch
DRIFT_ALERT_THRESHOLD_T2=0.60   # Concern
DRIFT_ALERT_THRESHOLD_T3=0.75   # Alert (notify clinical lead)
DRIFT_ALERT_THRESHOLD_T4=0.90   # Critical (immediate escalation)

# Minimum number of observations before baseline is considered valid
BASELINE_MIN_OBSERVATIONS=14

# How often to recalculate baselines (hours)
BASELINE_RECALCULATION_INTERVAL_HOURS=6

# ------------------------------------------------------------
# Webhooks
# ------------------------------------------------------------
WEBHOOK_SIGNING_SECRET=dev-webhook-signing-secret-change-in-production
WEBHOOK_TIMEOUT_SECONDS=10
WEBHOOK_RETRY_ATTEMPTS=3
WEBHOOK_RETRY_BACKOFF_SECONDS=30

# ------------------------------------------------------------
# FHIR Integration (optional)
# ------------------------------------------------------------
FHIR_ENABLED=false
FHIR_SERVER_URL=https://your-fhir-server.example.com/fhir
FHIR_AUTH_TOKEN=your-fhir-bearer-token

# ------------------------------------------------------------
# Email Alerts (optional — for direct staff notifications)
# ------------------------------------------------------------
EMAIL_ENABLED=false
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=your-sendgrid-api-key
EMAIL_FROM=alerts@behavedrift.io
EMAIL_FROM_NAME=BehaveDrift Alerts

# ------------------------------------------------------------
# Rate Limiting
# ------------------------------------------------------------
# Requests per minute per API key (0 = disabled)
RATE_LIMIT_REQUESTS_PER_MINUTE=300
RATE_LIMIT_BURST=50

# ------------------------------------------------------------
# Observability
# ------------------------------------------------------------
# OpenTelemetry tracing (optional)
OTEL_ENABLED=false
OTEL_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=behavedrift-api

# Sentry error tracking (optional)
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1

# ------------------------------------------------------------
# Security
# ------------------------------------------------------------
# CORS — comma-separated list of allowed origins
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080
CORS_ALLOW_CREDENTIALS=false

# GDPR erasure audit log retention (days)
GDPR_AUDIT_LOG_RETENTION_DAYS=3650  # 10 years

# Data retention (days, 0 = indefinite)
OBSERVATION_RETENTION_DAYS=2555    # 7 years
ALERT_RETENTION_DAYS=2555          # 7 years
